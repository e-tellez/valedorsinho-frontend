# =============================================================================
# valedorsinho-frontend — environment variables
# Copy this file to .env.local and fill in real values before running.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Mock mode (contributor-friendly local dev — no backend required)
# Set to "true" to intercept all /api/* calls with MSW (Mock Service Worker).
# When enabled, every Adyen flow uses pre-canned mock responses locally.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MOCK_API=false

# -----------------------------------------------------------------------------
# Valedorsinho FastAPI backend (Railway)
# Required when NEXT_PUBLIC_MOCK_API=false.
# Development: point to local FastAPI (http://localhost:8000)
# Production:  point to Railway deployment URL
# -----------------------------------------------------------------------------
VALEDORSINHO_API_URL=http://localhost:8000
NEXT_PUBLIC_VALEDORSINHO_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Supabase — Project Settings → API
# Required for all auth flows (OTP magic link).
# Create a free project at https://supabase.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# -----------------------------------------------------------------------------
# App base URL (no trailing slash)
# Used to build absolute returnUrl values for Adyen redirect flows
# and to construct the Supabase magic-link emailRedirectTo URL.
# Development: http://localhost:3000
# Production:  https://valedorsinho.etellez.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Adyen backend base URL (production only — used for server-side health checks)
# -----------------------------------------------------------------------------
ADYEN_BACKEND_URL=https://valedorsinho.up.railway.app

# -----------------------------------------------------------------------------
# Adyen fallback credentials (server-only — never exposed to the browser)
# Used by GET /api/config/client when the authenticated user has no row in
# adyen_configs (e.g. shared demo deployments where everyone uses one account).
# If a user has their own config saved via the Setup page these values are
# ignored for that user.
# Leave blank to require every user to complete the Setup step individually.
# -----------------------------------------------------------------------------
ADYEN_DEFAULT_CLIENT_KEY=
ADYEN_DEFAULT_MERCHANT_ACCOUNT=
